{
  "name": "@mymemory/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "create-user": "node scripts/create-user.mjs",
    "migration:run": "tsx src/migration-cli.ts run",
    "migration:revert": "tsx src/migration-cli.ts revert",
    "migration:show": "tsx src/migration-cli.ts show",
    "migration:create": "typeorm migration:create"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.4",
    "@kenjiuno/msgreader": "^1.28.0",
    "@mymemory/shared": "*",
    "@napi-rs/canvas": "^0.1.98",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "mailparser": "^3.9.6",
    "mammoth": "^1.12.0",
    "mysql2": "^3.12.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.4",
    "tesseract.js": "^5.1.1",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
