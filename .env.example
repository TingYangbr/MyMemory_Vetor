# API
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Uma origem ou várias separadas por vírgula (deve bater com a URL do front no navegador).
# Em dev, se omitir, a API aceita http://localhost:5173 e http://127.0.0.1:5173.
# CORS_ORIGIN=http://localhost:5173
PUBLIC_WEB_URL=http://localhost:5173

# E-mail (Resend) — cadastro, confirmação e esqueci a senha
# RESEND_API_KEY=
# EMAIL_FROM=MyMemory <contato@seudominio.com.br>

# MySQL (use docker-compose or local instance)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mymemory
MYSQL_PASSWORD=mymemory_secret
MYSQL_DATABASE=mymemory

# Dev: sem JWT, usar sempre o usuário DEV_USER_ID (predefinição em dev). Para forçar login:
# USE_DEV_FALLBACK=0
# DEV_USER_ID=1

# Mídia (SaaS)
# S3 AWS: STORAGE_MODE=s3 ou MEDIA_STORAGE=s3; S3_BUCKET_NAME ou S3_BUCKET; AWS_REGION (ou S3_REGION).
# URL pública dos objetos: S3_PUBLIC_URL ou S3_PUBLIC_BASE_URL (ex.: https://bucket.s3.amazonaws.com ou CloudFront).
# Credenciais: AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY no .env, ou omita em EC2/ECS com IAM role.
# Disco local: não defina STORAGE_MODE s3; em produção MEDIA_LOCAL_PUBLIC=0 — GET /media exige JWT.
# MEDIA_LOCAL_PUBLIC=0
# STORAGE_MODE=s3
# S3_BUCKET_NAME=my-bucket
# AWS_REGION=us-east-1
# S3_PUBLIC_URL=https://my-bucket.s3.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=          # só para MinIO / compatível S3

# OpenAI — processamento de memo texto (Básico / Completo)
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_WHISPER_LANGUAGE=     # vazio explícito = Whisper deteta o idioma (pode errar em ruído)
# OPENAI_WHISPER_LANGUAGE=pt    # forçar português (recomendado se omitir a linha acima: o API usa pt por defeito)
